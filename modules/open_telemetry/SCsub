#!/usr/bin/env python
from misc.utility.scons_hints import *

Import("env")
Import("env_modules")

env_otel = env_modules.Clone()

# Pull in SQLite module headers so otel_exporter_sqlite.cpp can see godot_sqlite.h
# and its transitive dependency spmemvfs.h.  Nothing from SQLite leaks into the
# public otel_exporter_sqlite.h — only the .cpp includes godot_sqlite.h.
env_otel.Prepend(CPPPATH=[
    "#modules/sqlite",
    "#modules/sqlite/src",
    "#modules/sqlite/thirdparty",
])

module_obj = []

# Main module files
env_otel.add_source_files(module_obj, "*.cpp")

# Structure classes
env_otel.add_source_files(module_obj, "structures/*.cpp")

# Add test sources if tests are enabled
if env["tests"]:
    env_otel.add_source_files(env.modules_sources, "./tests/*.cpp")
    env_otel.Append(CPPDEFINES=["TESTS_ENABLED"])

env.modules_sources += module_obj
